<launch>
    <node pkg="path_planning" exec="grid_search_planner" name="grid_search_planner" output="screen">
        
        <param name="odom_topic" value="/odom"/>
        <param name="map_topic" value="/map"/>
        <param name="safety_cell_radius" value="5"/>
        <param name="publish_path" value="True"/>
        <param name="path_topic" value="/trajectory/grid_search_trajectory"/>
        <param name="viz_namespace" value="/grid_search_trajectory"/>
        <!--color value is an array [r,g,b,alpha] in range [0.0,1.0]-->
        <param name="viz_traj_color" value="[1.0,0.0,0.0,0.6]"/> 

    </node>

    <node pkg="path_planning" exec="sampling_planner" name="sampling_planner" output="screen">
        
        <param name="odom_topic" value="/initialpose"/>
        <param name="map_topic" value="/map"/>
        <param name="rover_radius" value="0.2"/>
        <param name="offline" value="False"/>
        <param name="num_nodes" value="250"/>
        <param name="publish_path" value="True"/>
        <param name="path_topic" value="/trajectory/sampling_trajectory"/>
        <param name="viz_namespace" value="/sampling_trajectory"/>
        <!--color value is an array [r,g,b,alpha] in range [0.0,1.0]-->
        <param name="viz_traj_color" value="[0.0,0.0,1.0,0.6]"/>

    </node>

    <node pkg="path_planning" exec="path_analyzer" name = "path_analyzer" output="screen">
        <param name="odom_topic" value="/odom"/>
        <param name="traj_topics" value="['/trajectory/grid_search_trajectory','/trajectory/sampling_trajectory']"/>
        <param name="traj_names" value="['Grid Search','Sampling']"/>

    </node>
</launch>